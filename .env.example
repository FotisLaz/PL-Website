# Database Configuration
DATABASE_URL=jdbc:postgresql://postgres:5432/prem_stats
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_secure_password_here

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# Spring Profiles
SPRING_PROFILES_ACTIVE=dev

# AWS Configuration (for production)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=eu-west-1

# Production Database (AWS RDS)
PROD_DATABASE_URL=jdbc:postgresql://your-rds-endpoint:5432/prem_stats
PROD_DATABASE_USERNAME=your_prod_username
PROD_DATABASE_PASSWORD=your_prod_password
